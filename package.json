{
  "name": "immich-to-google-photos-migrator",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build --compile --minify --bytecode ./index.ts --outfile out/immich-to-google-photos-migrator --target bun-linux-x64 && chmod +x out/immich-to-google-photos-migrator",
    "deploy": "rsync -avz --perms out/immich-to-google-photos-migrator $DEPLOY_HOST:/usr/local/bin/immich-to-google-photos-migrator"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "effect": "^3.21.2"
  }
}
